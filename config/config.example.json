{
  "example.com": {
    "upstream": "https://example.com",
    "host_override": "",
    "request_headers": {
      "X-Custom-Header": "MyValue"
    },
    "response_headers": {
      "X-Response-Header": "ResponseValue"
    },
    "remove_headers": [
      "Server",
      "X-Powered-By",
      "Set-Cookie"
    ]
  },
  "another.com": {
    "upstream": "https://another.com",
    "host_override": "",
    "request_headers": {
      "X-Another-Header": "AnotherValue"
    },
    "response_headers": {
      "X-Another-Response": "AnotherResponseValue"
    },
    "remove_headers": [
      "Server",
      "Set-Cookie"
    ]
  },
  "conditional.com": {
    "upstream": "https://conditional-upstream.com",
    "host_override": "",
    "request_headers": {
      "X-Conditional": "CondValue"
    },
    "response_headers": {
      "X-Conditional-Response": "CondResponse"
    },
    "remove_headers": [
      "Server"
    ],
    "condition": {
      "header": "X-Api-Key",
      "value": "secret-key"
    },
    "fallback_behavior": "fallback_upstream",
    "fallback_upstream": "https://fallback-upstream.com"
  },
  "append.com": {
    "upstream": "http://localhost:8081",
    "path_rewrite_regex": "^/(.*)",
    "path_rewrite_replacement": "/api/$1"
  },
  "remove.com": {
    "upstream": "http://localhost:8082",
    "path_rewrite_regex": "^/v1/(.*)",
    "path_rewrite_replacement": "/$1"
  },
  "replace.com": {
    "upstream": "http://localhost:8083",
    "path_rewrite_regex": "^/old/(.*)",
    "path_rewrite_replacement": "/new/$1"
  }
}