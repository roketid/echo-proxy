{
  "httpbin.local": {
    "upstream": "https://httpbin.org",
    "host_override": "httpbin.org",
    "request_headers": {
      "X-Custom-Header": "MyValue",
      "X-Proxy": "echo-proxy"
    },
    "response_headers": {
      "X-Response-Header": "ResponseValue"
    },
    "remove_headers": [
      "Server"
    ],
    "dial_timeout": 30,
    "read_timeout": 30,
    "idle_timeout": 90
  },
  "api.httpbin.local": {
    "upstream": "https://httpbin.org",
    "host_override": "httpbin.org",
    "request_headers": {
      "X-Api-Version": "v1"
    },
    "response_headers": {
      "X-Response-Version": "v1"
    },
    "remove_headers": [
      "Server"
    ]
  },
  "conditional.httpbin.local": {
    "upstream": "https://httpbin.org/get",
    "host_override": "httpbin.org",
    "request_headers": {
      "X-Conditional": "True"
    },
    "response_headers": {
      "X-Conditional-Response": "Allowed"
    },
    "remove_headers": [
      "Server"
    ],
    "condition": {
      "header": "X-Api-Key",
      "value": "secret-key-12345"
    },
    "fallback_behavior": "fallback_upstream",
    "fallback_upstream": "https://httpbin.org/status/403"
  },
  "append.httpbin.local": {
    "upstream": "https://httpbin.org",
    "host_override": "httpbin.org",
    "path_rewrite_regex": "^/(.*)",
    "path_rewrite_replacement": "/$1",
    "dial_timeout": 15,
    "read_timeout": 20
  },
  "remove-prefix.httpbin.local": {
    "upstream": "https://httpbin.org",
    "host_override": "httpbin.org",
    "path_rewrite_regex": "^/api/v1/(.*)",
    "path_rewrite_replacement": "/$1"
  },
  "rewrite.httpbin.local": {
    "upstream": "https://httpbin.org",
    "host_override": "httpbin.org",
    "path_rewrite_regex": "^/old/(.*)",
    "path_rewrite_replacement": "/new/$1"
  }
}